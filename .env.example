# 複製為 .env 後填入實際值:cp .env.example .env
# .env 已列入 .gitignore,絕對不可 commit

# --- PostgreSQL(docker-compose.dev.yml 與 backend dev profile 共用)---
POSTGRES_DB=seckill
POSTGRES_USER=seckill
POSTGRES_PASSWORD=change-me-postgres

# --- RabbitMQ ---
RABBITMQ_USER=seckill
RABBITMQ_PASSWORD=change-me-rabbitmq

# --- JWT(M1 起使用;至少 256 bit,可用 openssl rand -base64 48 產生)---
JWT_SECRET=change-me-generate-a-random-256-bit-secret

# --- Grafana(M6 監控;admin 登入密碼,docker-compose.monitoring.yml 使用)---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# ===========================================================================
# 以下為 M7 正式環境(docker-compose.prod.yml)專用;dev / monitoring 不需要。
# 正式環境的 .env 由 cd.yml 依 GitHub Secrets 於部署時產生,不手動維護。
# ===========================================================================

# --- Redis 密碼(prod 一律 requirepass;dev 的 Redis 無密碼故上面沒有此項)---
REDIS_PASSWORD=change-me-redis

# --- Caddy / 對外網域 ---
# SITE_ADDRESS:正式網域(DuckDNS 等免費網域亦可,例:seckill.duckdns.org);
#              本機驗證 prod compose 時可填 localhost(Caddy 改用內建 CA 自簽)。
SITE_ADDRESS=seckill.example.duckdns.org
# ACME_EMAIL:Let's Encrypt 註冊信箱(必填;留空會使 Caddy 設定解析失敗)。
ACME_EMAIL=you@example.com

# --- 自家映像 tag(cd.yml 部署時帶 git SHA;手動起 prod 可用 latest)---
IMAGE_TAG=latest

# --- 限流閾值覆寫(選填;不設則用 application.yml 的設計初值)---
# 壓測從單機打時,單 IP 10/s 會把 k6 卡在 10 QPS,屆時調高 SECKILL_RL_IP。
# SECKILL_RL_GLOBAL=3000
# SECKILL_RL_USER=2
# SECKILL_RL_IP=10
# SECKILL_RL_TOKEN_USER=5
