# 複製為 .env 後填入實際值:cp .env.example .env
# .env 已列入 .gitignore,絕對不可 commit

# --- PostgreSQL(docker-compose.dev.yml 與 backend dev profile 共用)---
POSTGRES_DB=seckill
POSTGRES_USER=seckill
POSTGRES_PASSWORD=change-me-postgres

# --- RabbitMQ ---
RABBITMQ_USER=seckill
RABBITMQ_PASSWORD=change-me-rabbitmq

# --- JWT(M1 起使用;至少 256 bit,可用 openssl rand -base64 48 產生)---
JWT_SECRET=change-me-generate-a-random-256-bit-secret
