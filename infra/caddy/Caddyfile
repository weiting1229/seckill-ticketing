# 對外唯一入口(M7)。設計文件第 10.4、10.7 節與 ADR 0004 §4 為權威依據。
#
# SITE_ADDRESS 由 docker-compose.prod.yml 經 env 注入(例:seckill.duckdns.org),
# 便於在免費網域 / 正式網域 / 本機驗證之間切換而不動本檔。
# 填真實網域時 Caddy 會自動申請並續期 Let's Encrypt 憑證;
# 填 localhost 時 Caddy 改用內建本機 CA 簽發自簽憑證(本機驗證用,不觸碰 ACME)。
{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
	encode gzip zstd

	# --- 安全 header(設計第 10.4 節)---
	header {
		# 僅在 HTTPS 下有意義;Caddy 一律自動導向 HTTPS
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# 基本 CSP。style-src 需 'unsafe-inline':Element Plus 於執行期注入 inline style;
		# script 無需 'unsafe-eval'(Vite 產出的是 runtime-only 建置,SFC 模板已預先編譯)。
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# 不洩漏伺服器版本
		-Server
	}

	# --- actuator 一律不對外(設計第 10.7 節)---
	# 必須顯式攔截:否則會落到下方的 catch-all → 前端 SPA fallback 回 200 index.html。
	# actuator 只給 Docker 內網的 Prometheus 抓,對外一律 404(404 而非 403,不洩漏端點存在性)。
	handle /actuator/* {
		respond 404
	}

	# --- API 反代 ---
	#
	# 【XFF 信任模型 — 動這段前務必先讀】
	# 後端取 X-Forwarded-For「最左值」當 client IP(ClientRequestInfo),用於「單 IP 10/s」
	# 限流。XFF 是客戶端可自行偽造的 header,若原封轉發,攻擊者每次換一個假 IP 即可繞過限流。
	#
	# ADR 0004 §4 因此建議此處寫 `header_up X-Forwarded-For {remote_host}` 覆寫。
	# 但實測(M7)證實在 Caddy 2.9 下該行為 no-op:Caddy 2.7 起採 trusted_proxies 信任模型,
	# 預設不信任任何上游,一律丟棄客戶端送來的 XFF 並改寫為真實連線來源。
	# 對照實驗(送 `X-Forwarded-For: 1.2.3.4`,觀察上游實收):
	#   有 header_up → 172.19.0.1(真實來源);無 header_up → 172.19.0.1(相同)
	# Caddy 亦會對該指令發出 "Unnecessary header_up X-Forwarded-For" 警告。故移除。
	#
	# 【後果警告】此處的安全性依賴「Caddy 預設不信任任何上游」。若日後:
	#   (a) 設定 trusted_proxies,或 (b) 在 Caddy 前面再擺一層 CDN / LB(如 Cloudflare),
	# 則真實 client IP 的來源會改變,必須重新檢視此處與 ClientRequestInfo 的取值邏輯,
	# 否則限流可能失效(全部流量被視為同一個 IP)。詳見 ADR 0008。
	handle /api/* {
		reverse_proxy backend:8080
	}

	# --- 其餘交給前端靜態站 ---
	handle {
		reverse_proxy frontend:8080
	}
}
